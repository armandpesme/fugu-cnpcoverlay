{
  "chat.promptFiles": true,
  "chat.useAgentsMdFile": true,
  "chat.includeApplyingInstructions": true,
  "chat.includeReferencedInstructions": true,
  "chat.useCustomizationsInParentRepositories": false,
  "chat.useNestedAgentsMdFiles": false,
  "chat.promptFilesLocations": {
    ".github/prompts": true,
    "~/.copilot/prompts": false
  },
  "chat.instructionsFilesLocations": {
    ".github/instructions": true,
    "~/.copilot/instructions": false,
    "~/.claude/rules": false
  },
  "chat.agentSkillsLocations": {
    ".agents/skills": true,
    ".github/skills": false,
    ".claude/skills": false,
    "~/.copilot/skills": false,
    "~/.agents/skills": false,
    "~/.claude/skills": false
  },
  "chat.modeFilesLocations": {
    ".github/chatmodes": true
  },
  "chat.agentFilesLocations": {
    ".github/agents": true,
    "~/.copilot/agents": false
  },
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.chat.organizationInstructions.enabled": false,
  "chat.mcp.discovery.enabled": {
    "claude-desktop": false,
    "windsurf": false,
    "cursor-global": false,
    "cursor-workspace": false
},
  "chat.mcp.autostart": false,
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    }
  },
  "java.configuration.updateBuildConfiguration": "interactive",
  "commentTranslate.targetLanguage": "fr",
  "java.compile.nullAnalysis.mode": "automatic"
}
